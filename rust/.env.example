# WeChatBot Rust SDK 环境变量示例
#
# 用法：
# 1) 复制为 .env:   cp .env.example .env
# 2) 直接修改 .env 中的值
# 3) 程序启动会自动读取 .env（若缺失会自动从 .env.example 复制）

# =============================================================================
# 配置文件路径
# =============================================================================
# AppConfig TOML 文件路径，默认 rust/config/app.toml
WECHATBOT_CONFIG=config/app.toml

# =============================================================================
# 数据库 (PostgreSQL)
# =============================================================================
# 可选: local | container | remote
WECHATBOT_DATABASE_MODE=local
# 本地开发数据库连接
WECHATBOT_DATABASE_LOCAL_URL=postgres://postgres:postgres@localhost:5432/wechatbot
# 容器网络内数据库连接
WECHATBOT_DATABASE_CONTAINER_URL=postgres://postgres:postgres@postgres:5432/wechatbot
# 远程数据库连接（按需填写）
WECHATBOT_DATABASE_REMOTE_URL=

# =============================================================================
# Redis
# =============================================================================
# 可选: local | container | remote
WECHATBOT_REDIS_MODE=local
# 本地 Redis 连接
WECHATBOT_REDIS_LOCAL_URL=redis://127.0.0.1:6379
# 容器网络内 Redis 连接
WECHATBOT_REDIS_CONTAINER_URL=redis://redis:6379
# 远程 Redis 连接（按需填写）
WECHATBOT_REDIS_REMOTE_URL=

# =============================================================================
# Admin 服务
# =============================================================================
# 管理后台监听地址
WECHATBOT_ADMIN_BIND=127.0.0.1:8787
# 静态资源目录（相对 rust/ 或绝对路径）
WECHATBOT_ADMIN_STATIC_DIR=./static

# =============================================================================
# 会话与超时控制（单位：秒 / 毫秒）
# =============================================================================
# 二维码和注册链接展示有效期（秒）
WECHATBOT_QR_EXPIRE_SECS=3600
# online/offline 判定心跳超时阈值（秒）
WECHATBOT_SESSION_ONLINE_TIMEOUT_SECS=3600
# typing 持续保活刷新间隔（秒）
WECHATBOT_TYPING_KEEPALIVE_SECS=3600
# 上下文 token 过期时间（秒）
WECHATBOT_CONTEXT_EXPIRE_SECS=3600
# 长处理触发 typing 的阈值（毫秒）
WECHATBOT_TYPING_TRIGGER_MS=1000

# =============================================================================
# 测试
# =============================================================================
# 仅集成测试使用；未设置时相关测试会跳过或报缺失
WECHATBOT_TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5433/wechatbot
